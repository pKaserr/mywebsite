<IfModule mod_rewrite.c>
    RewriteEngine On

    # ClickJacking Protection (X-Frame-Options)
    # Verhindert, dass deine Seite in IFrames anderer Seiten geladen wird.
    Header set X-Frame-Options "DENY"
    Header always set X-Frame-Options "SAMEORIGIN"

    # Content Type Sniffing verhindern
    # Zwingt den Browser, den vom Server gesendeten MIME-Typ zu akzeptieren.
    Header set X-Content-Type-Options "nosniff"

    # HSTS (Strict-Transport-Security)
    # Sagt dem Browser: "Nutze für dieses Jahr nur noch HTTPS!"
    # Wichtig: Erst aktivieren, wenn HTTPS stabil läuft.
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # Content Security Policy (CSP)
    # Ein White-Listing-System, das festlegt, woher Skripte und Bilder geladen werden dürfen.
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://patrick-kaserer.de;"

    # Erzwinge HTTPS
    # Hinweis: Falls du Cloudflare nutzt, prüfe dort auch die Option "Always Use HTTPS"
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
    
    # Basis-Pfad (Root Verzeichnis auf dem Webspace)
    RewriteBase /

    # cloudflare-Whitelist (cdn-cgi Pfade ignorieren)
    # Damit wird die E-Mail-Protection von Cloudflare nicht an deine index.php weitergeleitet
    RewriteCond %{REQUEST_URI} ^/cdn-cgi/
    RewriteRule ^ - [L]

    # Regel 1: Existiert die Datei real? (Bilder, CSS, JS)
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # Regel 2: Existiert der Ordner real?
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Regel 3: Alles andere an die index.php (Dein PHP-Router)
    RewriteRule ^ index.php [L]
</IfModule>